<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- Top Bar: Locale (left), Info (center), QR (right) -->

    <ImageButton
        android:id="@+id/infoButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="48dp"
        android:backgroundTint="@color/background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.013"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/info" />

    <ImageButton
        android:id="@+id/qrButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="48dp"
        android:backgroundTint="@color/background"
        app:srcCompat="@drawable/qrcode"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Copy button INSIDE the ID field -->
    <TextView
        android:id="@+id/idLabel"
        android:layout_width="148dp"
        android:layout_height="22dp"
        android:layout_marginTop="32dp"
        android:text="@string/your_id"
        android:textAlignment="center"
        android:textColor="@color/text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/infoButton" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/showIdField"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/popup_border"
        android:clickable="false"
        android:cursorVisible="false"
        android:focusable="false"
        android:gravity="center"
        android:minHeight="44dp"
        android:paddingEnd="40dp"
        android:textColor="@color/text"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/idLabel" />

    <ImageButton
        android:id="@+id/copyButton"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:backgroundTint="@android:color/transparent"
        android:background="@android:color/transparent"
        app:srcCompat="@drawable/copy"
        app:layout_constraintEnd_toEndOf="@id/showIdField"
        app:layout_constraintTop_toTopOf="@id/showIdField"
        app:layout_constraintBottom_toBottomOf="@id/showIdField"
        android:layout_marginEnd="12dp" />

    <TextView
        android:id="@+id/idDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/unable_to_show_key"
        android:textColor="@color/text"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/showIdField"
        app:layout_constraintEnd_toEndOf="@+id/showIdField"
        app:layout_constraintStart_toStartOf="@+id/showIdField"
        app:layout_constraintTop_toTopOf="@+id/showIdField" />


    <!--Wipe time limit dropdown-->

    <androidx.appcompat.widget.AppCompatSpinner
        android:id="@+id/wipe_time_options"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="104dp"
        android:background="@drawable/spinner_dropdown"
        android:minHeight="44dp"
        android:paddingStart="0dp"
        android:paddingEnd="40dp"
        android:popupBackground="#FFFFFF"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@+id/showIdField"
        app:layout_constraintStart_toStartOf="@+id/showIdField"
        app:layout_constraintTop_toBottomOf="@+id/showIdField"/>


    <TextView
        android:id="@+id/wipe_time_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text"
        android:text="@string/wipe_time_no_unlock"
        app:layout_constraintBottom_toBottomOf="@+id/wipe_time_options"
        app:layout_constraintEnd_toEndOf="@+id/wipe_time_options"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="@+id/wipe_time_options"
        app:layout_constraintTop_toBottomOf="@+id/idLabel"
        app:layout_constraintVertical_bias="0.686" />

    <TextView
        android:id="@+id/custom_time_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/wipe_time_options"
        app:layout_constraintStart_toStartOf="@id/wipe_time_options"
        app:layout_constraintEnd_toEndOf="@id/wipe_time_options"
        android:layout_marginTop="8dp"/>

    <!-- Protection Toggle Section -->
    <TextView
        android:id="@+id/protection_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Emergency Protection"
        android:textColor="@color/text"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/wipe_time_options"
        app:layout_constraintStart_toStartOf="@id/wipe_time_options"
        android:layout_marginTop="40dp"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/protection_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="false"
        android:minHeight="44dp"
        app:layout_constraintTop_toTopOf="@id/protection_label"
        app:layout_constraintBottom_toBottomOf="@id/protection_label"
        app:layout_constraintEnd_toEndOf="@id/wipe_time_options"/>

    <TextView
        android:id="@+id/protection_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Disabled"
        android:textColor="@color/text"
        android:textSize="12sp"
        android:alpha="0.7"
        app:layout_constraintTop_toBottomOf="@id/protection_label"
        app:layout_constraintStart_toStartOf="@id/wipe_time_options"
        app:layout_constraintEnd_toEndOf="@id/wipe_time_options"
        android:layout_marginTop="4dp"/>

    <!-- Trigger Selection Section -->
    <TextView
        android:id="@+id/triggers_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Active Triggers:"
        android:textColor="@color/text"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/protection_status"
        app:layout_constraintStart_toStartOf="@id/wipe_time_options"
        android:layout_marginTop="20dp"/>

    <CheckBox
        android:id="@+id/trigger_lock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Lock Timeout"
        android:textColor="@color/text"
        android:minHeight="44dp"
        android:checked="true"
        android:enabled="false"
        app:layout_constraintTop_toBottomOf="@id/triggers_label"
        app:layout_constraintStart_toStartOf="@id/wipe_time_options"
        app:layout_constraintEnd_toEndOf="@id/wipe_time_options"
        android:layout_marginTop="8dp"/>

    <CheckBox
        android:id="@+id/trigger_tile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Quick Settings Tile"
        android:textColor="@color/text"
        android:minHeight="44dp"
        android:checked="true"
        android:enabled="false"
        app:layout_constraintTop_toBottomOf="@id/trigger_lock"
        app:layout_constraintStart_toStartOf="@id/wipe_time_options"
        app:layout_constraintEnd_toEndOf="@id/wipe_time_options"/>

    <CheckBox
        android:id="@+id/trigger_notification"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Notification Listener"
        android:textColor="@color/text"
        android:minHeight="44dp"
        android:checked="true"
        android:enabled="false"
        app:layout_constraintTop_toBottomOf="@id/trigger_tile"
        app:layout_constraintStart_toStartOf="@id/wipe_time_options"
        app:layout_constraintEnd_toEndOf="@id/wipe_time_options"/>
</androidx.constraintlayout.widget.ConstraintLayout>
